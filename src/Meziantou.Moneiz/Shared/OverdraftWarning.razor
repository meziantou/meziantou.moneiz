@using Meziantou.Moneiz.Core
@inject DatabaseProvider DatabaseProvider
@implements IDisposable

@if (hasOverdraftAccounts)
{
    <div class="overdraft-warning-container">
        <div class="container">
            <div class="alert alert-warning overdraft-warning">
                <i class="fas fa-exclamation-triangle"></i>
                <strong>Overdraft Warning:</strong>
                @if (overdraftAccounts.Count == 1)
                {
                    var info = overdraftAccounts[0];
                    var daysUntil = info.OverdraftDate.DayNumber - today.DayNumber;
                    <span>
                        Account <strong>@info.Account.Name</strong> will fall below <strong>@FormatAmount(info.Account.OverdraftNotificationAmount, info.Account.CurrencyIsoCode)</strong>
                        @if (daysUntil == 0)
                        {
                            <text> today</text>
                        }
                        else
                        {
                            <text> on <strong>@info.OverdraftDate.ToString("yyyy-MM-dd")</strong></text>
                        }
                        <text> (projected balance: <strong>@FormatAmount(info.LowestBalance, info.Account.CurrencyIsoCode)</strong>).</text>
                    </span>
                }
                else
                {
                    <span>
                        @foreach (var info in overdraftAccounts)
                        {
                            if (info != overdraftAccounts[0])
                            {
                                <text>, </text>
                            }
                            var daysUntil = info.OverdraftDate.DayNumber - today.DayNumber;
                            <strong>@info.Account.Name</strong>
                            <text> (</text>
                            @if (daysUntil == 0)
                            {
                                <text>today</text>
                            }
                            else
                            {
                                <text>on @info.OverdraftDate.ToString("yyyy-MM-dd")</text>
                            }
                            <text>, balance: @FormatAmount(info.LowestBalance, info.Account.CurrencyIsoCode))</text>
                        }
                        <text> will fall below their minimum balance thresholds.</text>
                    </span>
                }
            </div>
        </div>
    </div>
}

@code {
    private record OverdraftAccountInfo(Account Account, DateOnly OverdraftDate, decimal LowestBalance);

    private List<OverdraftAccountInfo> overdraftAccounts = new();
    private bool hasOverdraftAccounts;
    private DateOnly today;
    private System.Threading.Timer? timer;

    protected override async Task OnInitializedAsync()
    {
        DatabaseProvider.DatabaseChanged += OnDatabaseChanged;
        timer = new System.Threading.Timer(CheckOverdraft, state: null, TimeSpan.Zero, TimeSpan.FromMinutes(5));
        await CheckForOverdraft();
    }

    public void Dispose()
    {
        DatabaseProvider.DatabaseChanged -= OnDatabaseChanged;
        timer?.Dispose();
    }

    private void OnDatabaseChanged(object? sender, EventArgs e)
    {
        InvokeAsync(CheckForOverdraft);
    }

    private void CheckOverdraft(object? state)
    {
        InvokeAsync(CheckForOverdraft);
    }

    private async Task CheckForOverdraft()
    {
        try
        {
            var db = await DatabaseProvider.GetDatabase();
            today = Database.GetToday();

            overdraftAccounts.Clear();

            foreach (var account in db.VisibleAccounts.Where(a => a.OverdraftNotificationEnabled))
            {
                var days = account.OverdraftNotificationCheckPeriodDays;
                var minimumBalance = account.OverdraftNotificationAmount;

                DateOnly? overdraftDate = null;
                decimal lowestBalance = decimal.MaxValue;

                for (var i = 0; i <= days; i++)
                {
                    var checkDate = today.AddDays(i);
                    var balance = db.GetBalance(account, checkDate);

                    if (balance < minimumBalance)
                    {
                        overdraftDate ??= checkDate;
                        if (balance < lowestBalance)
                        {
                            lowestBalance = balance;
                        }
                    }
                }

                if (overdraftDate.HasValue)
                {
                    overdraftAccounts.Add(new OverdraftAccountInfo(account, overdraftDate.Value, lowestBalance));
                }
            }

            hasOverdraftAccounts = overdraftAccounts.Count > 0;
            StateHasChanged();
        }
        catch
        {
            // Ignore errors during check
        }
    }

    private static string FormatAmount(decimal amount, string? currencyCode)
    {
        var sign = amount >= 0 ? "" : "-";
        var absAmount = Math.Abs(amount);
        return $"{sign}{absAmount:N2} {currencyCode ?? ""}".Trim();
    }
}
